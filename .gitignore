# LOCAL DIRECTORY FOR ALL TEMPORARY FILES
# All temporary, session, cache, and local-only files go here
.local/

# Virtual environment
.venv/
venv/
env/

# Python bytecode
__pycache__/
*.pyc

# Build and distribution
build/
dist/
*.egg-info/
.eggs/
wheel/

# Coverage (pytest-cov defaults)
.coverage
htmlcov/

# Tool caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Financial statements (sensitive data)
statements/

# Private configuration files (user-specific, not versioned)
config/private_settings.toml
config/private_mappings.toml

# Keep templates versioned
!config/templates/

# Claude Code and Droid development (local only, never commit)
.claude/
*CLAUDE.md
.factory/
.droid/
AGENTS.md
*.spec.md

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment variables (never commit secrets)
.env
.env.local
.env.*.local
